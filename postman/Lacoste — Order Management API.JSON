    "name": "Lacoste — Order Management API",
    "description": "Complete API test suite for the Order Management feature.\n\nCovers: Order Search, Release, Cancel, Ship, Return, and Short actions.\n\nEnvironment variables required:\n- `baseUrl` → API base URL (e.g. https://postman-echo.com)\n- `orderId` → e.g. GFR35150_12356\n- `country` → e.g. FR\n\nAuthor: Hamza BOUNAAMANE",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "27424896"
  },
  "item": [
    {
      "name": "🔍 Order Search",
      "item": [
        {
          "name": "TC001 — Search valid order (Happy Path)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Simulate real API response for demo purposes",
                  "const mockResponse = {",
                  "  orderId: pm.collectionVariables.get('orderId'),",
                  "  country: pm.collectionVariables.get('country'),",
                  "  source: 'MAO',",
                  "  status: 'PENDING',",
                  "  items: [",
                  "    { itemId: '3666165426757', qty: 2, location: 'EU3', releaseId: 'GFR35150_123561', releaseLineId: 1, orderLineId: '35150_LINE-1780490028058', shipped: false },",
                  "    { itemId: '3666165426658', qty: 2, location: 'EU3', releaseId: 'GFR35150_123561', releaseLineId: 2, orderLineId: '35150_LINE-1780489962919', shipped: false }",
                  "  ]",
                  "};",
                  "",
                  "pm.test('Status 200 OK', () => pm.response.to.have.status(200));",
                  "",
                  "pm.test('orderId matches search param', () => {",
                  "  pm.expect(mockResponse.orderId).to.eql(pm.collectionVariables.get('orderId'));",
                  "});",
                  "",
                  "pm.test('country matches search param', () => {",
                  "  pm.expect(mockResponse.country).to.eql(pm.collectionVariables.get('country'));",
                  "});",
                  "",
                  "pm.test('source is MAO', () => {",
                  "  pm.expect(mockResponse.source).to.eql('MAO');",
                  "});",
                  "",
                  "pm.test('Response contains 2 items', () => {",
                  "  pm.expect(mockResponse.items).to.be.an('array').with.lengthOf(2);",
                  "});",
                  "",
                  "pm.test('Each item has required fields', () => {",
                  "  mockResponse.items.forEach(item => {",
                  "    pm.expect(item).to.have.all.keys('itemId','qty','location','releaseId','releaseLineId','orderLineId','shipped');",
                  "  });",
                  "});",
                  "",
                  "pm.test('Item qty is a positive integer', () => {",
                  "  mockResponse.items.forEach(item => {",
                  "    pm.expect(item.qty).to.be.a('number').and.above(0);",
                  "  });",
                  "});",
                  "",
                  "pm.test('Shipped flag is boolean false initially', () => {",
                  "  mockResponse.items.forEach(item => {",
                  "    pm.expect(item.shipped).to.be.a('boolean').and.eql(false);",
                  "  });",
                  "});",
                  "",
                  "// Store releaseId for subsequent requests",
                  "pm.collectionVariables.set('releaseId', mockResponse.items[0].releaseId);",
                  "pm.collectionVariables.set('orderLineId1', mockResponse.items[0].orderLineId);",
                  "pm.collectionVariables.set('orderLineId2', mockResponse.items[1].orderLineId);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "X-Request-ID",
                "value": "{{$guid}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/get?orderId={{orderId}}&country={{country}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "get"
              ],
              "query": [
                {
                  "key": "orderId",
                  "value": "{{orderId}}"
                },
                {
                  "key": "country",
                  "value": "{{country}}"
                }
              ]
            },
            "description": "P0 — Search an existing order by ID and country. Validates structure and all item fields."
          },
          "response": [
            {
              "name": "200 OK — Order Found",
              "originalRequest": {
                "method": "GET",
