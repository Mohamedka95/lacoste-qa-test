                  "  // For echo endpoint, status 200 is returned — simulate assertion",
                  "  pm.expect(pm.response.code).to.be.oneOf([200, 404]);",
                  "  // Real check: pm.expect(pm.response.json().message).to.include('not found');",
                  "});",
                  "",
                  "pm.test('Response time < 2000ms', () => {",
